VITE_SITE_DOMAIN=https://dociva.io
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_PLAUSIBLE_DOMAIN=dociva.io
VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
VITE_GOOGLE_SITE_VERIFICATION=
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_HOME_TOP=1234567890
VITE_ADSENSE_SLOT_HOME_BOTTOM=1234567891
VITE_ADSENSE_SLOT_TOP_BANNER=1234567892
VITE_ADSENSE_SLOT_BOTTOM_BANNER=1234567893

# IndexNow — fast URL submission to Bing & Yandex
# 1. Go to https://www.bing.com/webmasters → IndexNow → copy your key
# 2. Paste it here — the build will auto-create public/{key}.txt and update robots.txt
VITE_INDEXNOW_KEY=

# PayPal — only needed if PayPal JS SDK is loaded client-side.
# The Client ID is a PUBLIC key (safe to include in frontend builds).
# Never put PAYPAL_CLIENT_SECRET here — it must remain server-side only.
VITE_PAYPAL_CLIENT_ID=

# Feature Flags (set to "false" to disable a tool; enabled by default)
VITE_FEATURE_EDITOR=true
VITE_FEATURE_OCR=true
VITE_FEATURE_REMOVEBG=true

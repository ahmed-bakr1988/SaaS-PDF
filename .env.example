VITE_PLAUSIBLE_DOMAIN=dociva.io
VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
VITE_GOOGLE_SITE_VERIFICATION=
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=replace-with-a-long-random-secret-key
INTERNAL_ADMIN_EMAILS=support@dociva.io

# Site Domain (used in sitemap, robots.txt, emails)
SITE_DOMAIN=https://dociva.io
FRONTEND_URL=https://dociva.io
BACKEND_PUBLIC_URL=https://dociva.io

# ─── Social Auth (OAuth) ──────────────────────────────────────────────────────
#
# Each provider requires its own Developer Console setup.
# BACKEND_PUBLIC_URL above must match your production domain exactly.
# Leave a provider's keys blank to hide its button from the login screen.
#
# ── Google ────────────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create project → Enable "OAuth consent screen" (External, publish it)
# 3. Create credential → OAuth 2.0 Client ID → Web application
# 4. Add Authorized redirect URI:
#      https://dociva.io/api/auth/social/google/callback
# 5. Copy Client ID and Client Secret below.
GOOGLE_OAUTH_CLIENT_ID=529574733053-ql6m98ape9p8pn5qhfctsim7gokjhehu.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=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

# ── Facebook / Meta ───────────────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com/apps/ → Create App → Consumer
# 2. Add product: "Facebook Login for Business" → Web
# 3. Settings → Basic: copy App ID and App Secret below
# 4. Facebook Login → Settings → Valid OAuth Redirect URIs:
#      https://dociva.io/api/auth/social/facebook/callback
# 5. Add "email" and "public_profile" to required permissions.
# 6. Submit for App Review before going live (email permission requires review).
FACEBOOK_APP_ID=986721650460764
FACEBOOK_APP_SECRET=3065a93acf4dafb4213b43e82858e18d
FACEBOOK_GRAPH_API_VERSION=v23.0

# ── X (Twitter) ───────────────────────────────────────────────────────────────
# 1. Go to https://developer.x.com/en/portal/projects-and-apps → New App
# 2. App settings → Authentication settings:
#      - OAuth 2.0: ON
#      - Type of App: Web App
#      - Callback URI: https://dociva.io/api/auth/social/x/callback
#      - Website URL: https://dociva.io
# 3. To allow email collection: App settings → "Request email from users" → ON
#    (Requires Basic or higher developer plan)
# 4. Copy Client ID and Client Secret (OAuth 2.0 section) below.
# NOTE: If email permission is not enabled, X sign-in will fail for new users
#       who have no existing account. Existing users can still link their account.
X_CLIENT_ID=E9Ffhfh79K6Wjy7n5QLXNXIP5
X_CLIENT_SECRET=0JVdRyNL8A4hBS06B8OlI31w1H5F7mjbbOnpC5HnNsSlbxkCoo

# Redis
# Generate a strong password: openssl rand -hex 32
REDIS_PASSWORD=4dbdd770af118fee2acd680ed7099555a96a039f8bb3313fed819af0a33cce41
REDIS_URL=redis://:4dbdd770af118fee2acd680ed7099555a96a039f8bb3313fed819af0a33cce41@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:4dbdd770af118fee2acd680ed7099555a96a039f8bb3313fed819af0a33cce41@redis:6379/0
CELERY_RESULT_BACKEND=redis://:4dbdd770af118fee2acd680ed7099555a96a039f8bb3313fed819af0a33cce41@redis:6379/1

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Google Generative AI (fallback provider)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=chat-bison-001

# Premium document translation (recommended for Translate PDF)
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
DEEPL_TIMEOUT_SECONDS=90

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dociva-temp-files
AWS_S3_REGION=eu-west-1

# File Processing
MAX_CONTENT_LENGTH_MB=50
UPLOAD_FOLDER=/tmp/uploads
OUTPUT_FOLDER=/tmp/outputs
FILE_EXPIRY_SECONDS=1800
STORAGE_ALLOW_LOCAL_FALLBACK=true
# Use DATABASE_PATH for SQLite (development) or DATABASE_URL for PostgreSQL (production)
DATABASE_PATH=/app/data/dociva.db

# CORS
CORS_ORIGINS=https://dociva.io,https://www.dociva.io

# SMTP (Password reset + contact notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dociva.io
SMTP_USE_TLS=true

# Stripe Payments (legacy — kept for existing subscribers during PayPal transition)
# These keys are still required if you have active Stripe subscribers.
# New subscriptions will go through PayPal once PAYPAL_* keys are set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=

# PayPal Subscriptions (primary payment provider)
# 1. Create a PayPal Developer account at https://developer.paypal.com/
# 2. Create an App under "My Apps & Credentials" to get Client ID and Secret.
# 3. Create one Subscription Plan per tier in the PayPal dashboard and copy the Plan IDs.
# 4. Add a Webhook in the PayPal dashboard pointing to /api/paypal/webhook
#    and copy the Webhook ID shown after creation.
# PAYPAL_ENVIRONMENT: "sandbox" for testing, "live" for production
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=Af3RmrqIOV8OaQJUqso4xAcd7_mQzsM-8mKSQdOByaElPzByxbpANdqMnp4DB-7Khjt0xNbdWVWQ08et
PAYPAL_CLIENT_SECRET=EL8SltVJ8kjrg4FChm0zuvfTAzElf0hucn8PJ_yuqgIsYIoBU2S5Tk9vFEIWup1MdmXDhUhjPooAa5C1
PAYPAL_WEBHOOK_ID=

# ── Starter Plan ($4.99 / month) ─────────────────────────────────────────────
# Create a plan at https://developer.paypal.com/dashboard/subscriptions
PAYPAL_PLAN_ID_STARTER_MONTHLY=
PAYPAL_PLAN_ID_STARTER_YEARLY=
# Legacy micro plan ID — kept for existing micro subscribers (maps to Starter)
PAYPAL_PLAN_ID_MICRO=

# ── Pro Plan ($9.99 / month) ─────────────────────────────────────────────────
PAYPAL_PLAN_ID_PRO_MONTHLY=
PAYPAL_PLAN_ID_PRO_YEARLY=
# Optional: dedicated PayPal plan IDs with free-trial billing cycle built in
PAYPAL_PLAN_ID_PRO_MONTHLY_TRIAL=
PAYPAL_PLAN_ID_PRO_YEARLY_TRIAL=
# Number of days for the free trial period on Pro (set to 0 to disable)
PAYPAL_TRIAL_DAYS=2

# ── Business Plan ($29.99 / month) ───────────────────────────────────────────
PAYPAL_PLAN_ID_BUSINESS_MONTHLY=
PAYPAL_PLAN_ID_BUSINESS_YEARLY=

# PayMob Payments (MENA region — Egypt, etc.)
# 1. Create a PayMob account at https://portal.paymob.com/
# 2. Go to Settings → API Keys to get your Secret Key and Public Key.
# 3. Create an Integration (payment method) and copy the Integration ID.
# 4. For iframe checkout, create an Iframe and copy the Iframe ID.
# 5. Set up a Webhook in the PayMob portal pointing to /api/paymob/webhook
#    and copy the HMAC Secret.
# PAYMOB_ENVIRONMENT: "sandbox" for testing, "live" for production
PAYMOB_ENVIRONMENT=sandbox
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
# USD to EGP conversion rate (used for pricing in PayMob)
PAYMOB_USD_TO_EGP_RATE=50

# ── Credit Quota Overrides (optional — change defaults per plan) ──────────────
# FREE_CREDITS_PER_WINDOW=50
# STARTER_CREDITS_PER_WINDOW=200
# PRO_CREDITS_PER_WINDOW=1000
# FREE_MAX_FILE_SIZE_MB=25
# STARTER_MAX_FILE_SIZE_MB=250
# PRO_MAX_FILE_SIZE_MB=1024
# BUSINESS_MAX_FILE_SIZE_MB=2048


# Sentry Error Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# PostgreSQL (production)
DATABASE_URL=postgresql://dociva:${POSTGRES_PASSWORD}@postgres:5432/dociva
POSTGRES_DB=dociva
POSTGRES_USER=dociva
POSTGRES_PASSWORD=

# Frontend
VITE_SITE_DOMAIN=https://dociva.io
VITE_SENTRY_DSN=
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://www.bing.com/indexnow
INDEXNOW_AUTO_SUBMIT=true
